# Deploy with Supabase (no Postgres container)
# Copy to .env and fill in values.

# Your own image (build from your repo). Omit to use twentycrm/twenty:latest.
# APP_IMAGE=myapp:latest

# Supabase: use Connection string from Project Settings → Database
# Session pooler (recommended): port 6543
#   postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Direct: port 5432
#   postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
PG_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# URL users use to open the app (https or http with port)
SERVER_URL=https://your-domain.com

# Generate: openssl rand -base64 32
APP_SECRET=replace_me_with_a_random_string

# Redis (runs in Docker; change if you use external Redis)
REDIS_URL=redis://redis:6379

STORAGE_TYPE=local

# Optional: set to true only if you run migrations yourself
# DISABLE_DB_MIGRATIONS=false
